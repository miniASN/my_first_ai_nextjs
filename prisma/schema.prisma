generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id        String   @id @default(cuid())
  type      String   // "expense" or "income"
  amount    Float
  category  String
  title     String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
